# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit real secrets.

# ORCID OAuth2
# Register a sandbox app at https://sandbox.orcid.org/developer-tools
# Set redirect URI = http://localhost:3000/auth/callback in the ORCID app settings
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=http://localhost:3000/auth/callback

# JWT (RS256) — generate with: openssl genrsa -out jwt_private.key 4096
JWT_PRIVATE_KEY_PATH=./jwt_private.key
JWT_PUBLIC_KEY_PATH=./jwt_public.key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://scipeer:scipeer@localhost:5432/scipeer
# Optional read replica — leave blank if you don't have one
DATABASE_REPLICA_URL=

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3-compatible object storage
S3_ENDPOINT_URL=http://minio:9000
# URL reachable from the browser (for local dev: http://localhost:9000)
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_PAPERS=scipeer-papers
S3_BUCKET_BACKUPS=scipeer-backups

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=

# DataCite DOI
# Use https://api.datacite.org in production
DATACITE_API_URL=https://api.test.datacite.org
DATACITE_USERNAME=
DATACITE_PASSWORD=
DATACITE_PREFIX=10.XXXXX

# Email (SMTP)
# Mailpit in dev; change for production
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@scipeer.org

# App
# development | staging | production
APP_ENV=development
APP_BASE_URL=http://localhost:3000
SECRET_KEY=change-me-in-production
